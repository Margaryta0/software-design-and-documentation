{
  "info": {
    "name": "Group Chat Messenger API",
    "description": "Postman collection for Lab 2 — Variant 4: Group Chat with Fan-out delivery",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:51407" },
    { "key": "userId1", "value": "" },
    { "key": "userId2", "value": "" },
    { "key": "userId3", "value": "" },
    { "key": "groupId", "value": "" },
    { "key": "messageId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Users",
      "item": [
        {
          "name": "Create User Alice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userId1', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has id', () => pm.expect(json.id).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice\"\n}" },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Create User Bob",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userId2', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bob\"\n}" },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Create User Charlie",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userId3', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Charlie\"\n}" },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "List All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Create User — Empty Name (Error)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for empty name', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"\"\n}" },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        }
      ]
    },
    {
      "name": "2. Groups",
      "item": [
        {
          "name": "Create Group",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('groupId', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has 3 members', () => pm.expect(json.memberIds.length).to.equal(3));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dev Team\",\n  \"memberIds\": [\"{{userId1}}\", \"{{userId2}}\", \"{{userId3}}\"]\n}"
            },
            "url": { "raw": "{{baseUrl}}/groups", "host": ["{{baseUrl}}"], "path": ["groups"] }
          }
        },
        {
          "name": "Get Group by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Group name matches', () => pm.expect(pm.response.json().name).to.equal('Dev Team'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/groups/{{groupId}}", "host": ["{{baseUrl}}"], "path": ["groups", "{{groupId}}"] }
          }
        },
        {
          "name": "Get Group — Not Found (Error)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 for unknown group', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/groups/nonexistent-id", "host": ["{{baseUrl}}"], "path": ["groups", "nonexistent-id"] }
          }
        }
      ]
    },
    {
      "name": "3. Messages",
      "item": [
        {
          "name": "Send Message (Alice → Group)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('messageId', json.id);",
                  "pm.test('Status 202 Accepted', () => pm.response.to.have.status(202));",
                  "pm.test('Status is DeliveryInProgress', () => pm.expect(json.status).to.equal('DeliveryInProgress'));",
                  "pm.test('2 delivery entries (Bob + Charlie)', () => pm.expect(json.deliveryStatuses.length).to.equal(2));",
                  "pm.test('All enqueued', () => json.deliveryStatuses.forEach(ds => pm.expect(ds.state).to.equal('Enqueued')));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"{{userId1}}\",\n  \"text\": \"Hello everyone!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/messages", "host": ["{{baseUrl}}"], "path": ["groups", "{{groupId}}", "messages"] }
          }
        },
        {
          "name": "Send Message — Empty Text (Error)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for empty text', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senderId\": \"{{userId1}}\",\n  \"text\": \"\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/messages", "host": ["{{baseUrl}}"], "path": ["groups", "{{groupId}}", "messages"] }
          }
        },
        {
          "name": "Get Group Message History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has messages', () => pm.expect(pm.response.json().length).to.be.above(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/groups/{{groupId}}/messages", "host": ["{{baseUrl}}"], "path": ["groups", "{{groupId}}", "messages"] }
          }
        },
        {
          "name": "Get Single Message (with delivery statuses)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has deliveryStatuses', () => pm.expect(pm.response.json().deliveryStatuses).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/messages/{{messageId}}", "host": ["{{baseUrl}}"], "path": ["messages", "{{messageId}}"] }
          }
        }
      ]
    },
    {
      "name": "4. Delivery",
      "item": [
        {
          "name": "Process Deliveries (simulate worker)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('processedCount >= 0', () => pm.expect(json.processedCount).to.be.at.least(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/delivery/process", "host": ["{{baseUrl}}"], "path": ["delivery", "process"] }
          }
        },
        {
          "name": "Mark Message as Read (Bob)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientId\": \"{{userId2}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/messages/{{messageId}}/read", "host": ["{{baseUrl}}"], "path": ["messages", "{{messageId}}", "read"] }
          }
        }
      ]
    }
  ]
}
